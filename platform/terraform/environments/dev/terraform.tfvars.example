billing_account      = "AAAAAA-BBBBBB-CCCCCC"
org_id               = "123456789012"
# folder_id          = "123456789012"

labels = {
  environment = "dev"
  platform    = "aiopsvista"
  managed_by  = "terraform"
  cost_center = "demo"
}

budget_display_name            = "aiopsvista-dev-monthly-budget"
monthly_budget_amount          = 100
budget_currency_code           = "USD"
budget_threshold_percents      = [0.5, 0.75, 0.9, 1.0]
enable_forecast_alert          = true
forecast_threshold_percent     = 1.0
budget_notification_email      = "platform-team@example.com"
disable_default_iam_recipients = false

master_authorized_networks = [
  {
    cidr_block   = "203.0.113.10/32"
    display_name = "platform-admin"
  }
]

ai_finops_dataset_id                 = "ai_finops"
ai_finops_location                   = "US"
ai_finops_delete_contents_on_destroy = true
ai_finops_labels = {
  environment = "dev"
  platform    = "aiopsvista"
  managed_by  = "terraform"
  cost_center = "ai-finops"
}

ai_usage_collector_container_image        = "us-central1-docker.pkg.dev/aiopsvista-market-dev/ai-usage-collector/ai-usage-collector:latest"
ai_usage_collector_public_access          = false
ai_usage_collector_cpu                    = "1"
ai_usage_collector_memory                 = "512Mi"
ai_usage_collector_request_timeout_seconds = 300
ai_usage_collector_concurrency            = 20
ai_usage_collector_max_instance_count      = 1
ai_usage_collector_default_batch_size      = 3
